                });
                
                const result = await response.json();

                if (result.status === 'success') {
                    pesanArea.className = "mt-4 rounded-lg p-3 text-xs font-semibold text-center bg-emerald-100 text-emerald-700 shadow-sm block";
                    pesanArea.innerHTML = escapeHtml(result.message);
                    
                    formSelf.reset();
                    document.getElementById('previewContainer').classList.add('hidden');
                    document.getElementById('previewFoto').src = ""; fotoWatermarkBase64.value = "";
                    document.getElementById('containerLokasi').classList.add('hidden'); document.getElementById('lokasi').required = false;

                    btn.disabled = false; btn.innerHTML = 'Kirim Laporan Kehadiran'; btn.classList.replace('bg-slate-400', 'bg-emerald-600');
                    
                    // Tarik data terbaru untuk mengupdate feeds di dashboard
                    ambilDataDariGAS(); 
                    
                    // PERBAIKAN BUG: Otomatis kembali ke Home setelah pesan sukses muncul selama 2.5 detik
                    setTimeout(() => { 
                        pesanArea.classList.add('hidden'); 
                        goHome(); 
                    }, 2500);
                } else {
                    throw new Error(result.message);
                }
            } catch (error) {
                pesanArea.className = "mt-4 rounded-lg p-3 text-xs font-semibold text-center bg-red-100 text-red-700 shadow-sm block";
                pesanArea.innerHTML = "Gagal: " + escapeHtml(error.message);
                btn.disabled = false; btn.innerHTML = 'Coba Lagi'; btn.classList.replace('bg-slate-400', 'bg-emerald-600');
            }
        });
    </script>
</body>
</html>
