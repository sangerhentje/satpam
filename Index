        function hitungStatusKedisiplinan(nama, status, waktuStr, tanggalObj) {
            if (!polaShift || polaShift.length === 0) return null;

            const diffTime = Date.UTC(tanggalObj.getFullYear(), tanggalObj.getMonth(), tanggalObj.getDate()) - 
                             Date.UTC(anchorDate.getFullYear(), anchorDate.getMonth(), anchorDate.getDate());
            const diffDays = Math.floor(diffTime / (1000 * 60 * 60 * 24));
            let cycleIndex = diffDays % polaShift.length;
            if (cycleIndex < 0) cycleIndex += polaShift.length;

            const shiftHariIni = polaShift[cycleIndex]; 
            const parts = waktuStr.split(":");
            const hh = parseInt(parts[0], 10);
            const mm = parseInt(parts[1], 10);
            const menitAbsen = hh * 60 + mm;

            let shiftIndex = 0; let shiftTipe = "Pagi"; let batasMenitMasuk = 7 * 60; let batasMenitPulang = 15 * 60; 

            if (menitAbsen >= 300 && menitAbsen < 720) { shiftIndex = 0; shiftTipe = "Pagi"; batasMenitMasuk = 7 * 60; batasMenitPulang = 15 * 60; } 
            else if (menitAbsen >= 720 && menitAbsen < 1200) { shiftIndex = 1; shiftTipe = "Siang"; batasMenitMasuk = 15 * 60; batasMenitPulang = 23 * 60; } 
            else { shiftIndex = 2; shiftTipe = "Malam"; batasMenitMasuk = 23 * 60; batasMenitPulang = 7 * 60; }

            const personilTerjadwal = shiftHariIni[shiftIndex];
            let isSwap = (nama !== personilTerjadwal);
            let swapInfo = isSwap ? "Ganti " + personilTerjadwal : "";
            let tipeWarning = ""; let infoWarning = "";

            if (status === "Check-In (Masuk)") {
                if (menitAbsen > batasMenitMasuk) { tipeWarning = "Terlambat"; infoWarning = (menitAbsen - batasMenitMasuk) + " mnt"; }
            } else if (status === "Check-Out (Pulang)") {
                if (menitAbsen < batasMenitPulang) { tipeWarning = "Pulang Cepat"; infoWarning = (batasMenitPulang - menitAbsen) + " mnt"; }
            }

            if (isSwap || tipeWarning) { return { isSwap: isSwap, swapInfo: swapInfo, tipeWarning: tipeWarning, infoWarning: infoWarning }; }
            return null;
        }

